# LLM
GEMINI_API_KEY=your_key_here
# USE_MOCK_LLM=true            # 已未使用

# Kafka
# 從 host 執行 Decomposer CLI 時使用 localhost:29092
# 容器內的 Worker / Aggregator 使用 kafka:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Redis
REDIS_URL=redis://redis:6379/0

# Financial Data
FINNHUB_API_KEY=your_key_here
# USE_MOCK_FINANCE=false        # 已未使用

# System
LOG_LEVEL=INFO
# TASK_TIMEOUT_SECONDS=300     # 已未使用
# MAX_WORKER_ITERATIONS=3      # 已未使用
# WORKER_RETRY_MAX=3           # 已未使用
